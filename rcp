#!/usr/bin/env bash
# rcp — Rsync a folder from remote (or local) to local directory

SSH_PORT=8022

usage() {
    echo "Usage: ${0##*/} [-p PORT] <from> <to>"
    exit 0
}

# Parse options
while getopts ":p:h" opt; do
    case $opt in
        p) SSH_PORT="$OPTARG" ;;
        h) usage ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

FROM="$1"
TARGET="$2"

# Validate input
[[ -z "$FROM" || -z "$TARGET" ]] && usage

mkdir -p "$TARGET"
echo "[*] Syncing: $FROM → $TARGET"

# Base rsync args
ARGS=(-a --partial)

# Progress flag (version-aware)
rsync --version | head -n1 | grep -qE 'version 3\.[1-9]' \
    && ARGS+=(--info=progress2) \
    || ARGS+=(--progress)

# Add SSH if remote
[[ "$FROM" == *:* ]] && ARGS+=(-e "ssh -p $SSH_PORT")

# Run rsync
rsync "${ARGS[@]}" "$FROM/" "$TARGET/" || {
    echo "[!] rsync failed" >&2
    exit 1
}
